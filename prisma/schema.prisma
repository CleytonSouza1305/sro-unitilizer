// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @db.VarChar(255) @default(uuid()) @unique

  username String @db.VarChar(255)
  email String @db.VarChar(255) @unique
  password String @db.VarChar(255) 
  role UserRole @default(USER)

  created_by_id   String? @db.VarChar(255)
  created_by_user User?   @relation("UserCreator", fields: [created_by_id], references: [id])

  created_users   User[]  @relation("UserCreator")

  unitilizer_closeds Unitilizer[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  USER
}

model Unitilizer {
  id String @id @default(uuid())
  number Int 
  unitilizer String @db.VarChar(20) @unique
  destination String @db.VarChar(100)
  date String @db.VarChar(100)
  objects Objects[]

  closed_by_userId String
  closed_by_user User @relation(fields: [closed_by_userId], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Objects {
  id String @id @default(uuid())

  unitilizer_id String
  unitilizer Unitilizer @relation(fields: [unitilizer_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}